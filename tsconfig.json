{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.js",
    "__tests__/**/*.js",
    "scripts/**/*.js",
    "eslint.config.js",
    "jest.config.js"
  ]
}
